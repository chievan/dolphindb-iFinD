@testing:case = "test_thsBasicData_indicators_empty", exception=1
ifind::thsBasicData(accToken, "600519.SH", "")

@testing:case = "test_thsBasicData_indipara_type", exception=1
ifind::thsBasicData(accToken, "600519.SH", "ths_roe_stock", 100)


