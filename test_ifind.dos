// ====================================================
// 第三部分：功能反向测试 (Reverse Functional Tests)
// ====================================================

// --- 3.1 thsBasicData 内容反向 ---

@testing:case = "test_thsBasicData_invalid_codes", exception=1
// 格式正确(String)，但代码不存在
ifind::thsBasicData(accToken, "999999.ZZ", "ths_stock_short_name_stock")

@testing:case = "test_thsBasicData_invalid_indicators", exception=1
// 格式正确，但指标名错误
ifind::thsBasicData(accToken, "600519.SH", "ths_wrong_indicator_abc")

@testing:case = "test_thsBasicData_invalid_indipara", exception=1
// 格式正确，但参数 Key 或内容无效，能返回空值
