// ====================================================
// 第五部分：深度与并发验证 (Advanced Execution)
// ====================================================

@testing:case = "test_ConcurrentExecution"
print("\n=== [进阶] 并发执行测试 (thsRealTime) ===")
def iFindConcurrentCall(tk, codes, ind){
    total = 0
    for(i in 1..3){
        res = ifind::thsRealTime(tk, codes, ind)
        if(res.rows() > 0) total += 1
        sleep(500)
    }
    return total
}
jobs = array(STRING, 0)
for(i in 1..2){
    jobId = "ifind_rq_job_" + string(i)
    submitJob(jobId, "iFinD Parallel RQ", iFindConcurrentCall, accToken, "600519.SH", "latest")
    jobs.append!(jobId)
}
for(jid in jobs){ res = getJobReturn(jid, true); assert 11, res == 3 }

@testing:case = "test_ConcurrentExecution_DS"
print("\n=== [进阶] 并发执行测试 (thsDateSequence) ===")
def iFindConcurrentDS(tk, codes, ind, start, end){
    res = ifind::thsDateSequence(tk, codes, ind, "", "", start, end)
    return res.rows()
}
jobId1 = "ifind_ds_job_1"
submitJob(jobId1, "iFinD Parallel DS", iFindConcurrentDS, accToken, "000001.SZ", "ths_pe_ttm_stock", "2026-02-01", "2026-03-01")
res1 = getJobReturn(jobId1, true)
assert 12, res1 > 0


