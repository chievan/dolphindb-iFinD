@testing:case = "test_thsBasicData_codes_form", exception=1
ifind::thsBasicData(accToken, matrix(INT, 2, 2), "ths_roe_stock")

@testing:case = "test_thsBasicData_codes_null", exception=1
ifind::thsBasicData(accToken, NULL, "ths_roe_stock")

@testing:case = "test_thsBasicData_codes_empty_vec", exception=1
ifind::thsBasicData(accToken, array(STRING, 0), "ths_roe_stock")

@testing:case = "test_thsBasicData_codes_vec_with_null", exception=1
