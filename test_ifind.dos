@testing:case = "test_Correctness_TokenTypes"
print("\n=== [完善] 正确性: 支持 AccessToken 和 refreshToken ===")
// 测试直接传 refreshToken (内部会调用 getAccessToken)
tb_ref = ifind::thsRealTime(refreshToken, "600519.SH", "latest")
assert 13, tb_ref.rows() > 0
// 测试传 accToken
tb_acc = ifind::thsRealTime(accToken, "600519.SH", "latest")
assert 14, tb_acc.rows() > 0

@testing:case = "test_Correctness_VectorInputs"
print("\n=== [完善] 正确性: 支持 String Vector, bigarray, subarray ===")
codes_vec = ["600519.SH", "600000.SH"]
tb_vec = ifind::thsBasicData(accToken, codes_vec, "ths_stock_short_name_stock")
assert 15, tb_vec.rows() == 2

codes_big = bigarray(STRING, 0)
codes_big.append!(codes_vec)
tb_big = ifind::thsBasicData(accToken, codes_big, "ths_stock_short_name_stock")
assert 16, tb_big.rows() == 2

codes_sub = codes_vec.subarray(0:1)
tb_sub = ifind::thsBasicData(accToken, codes_sub, "ths_stock_short_name_stock")
assert 17, tb_sub.rows() == 1

@testing:case = "test_Correctness_LongVector", exception=1
// 构造一个长度 > 1024 的向量 (验证 checkCodes 逻辑及 iFinD API 请求限制)
long_vec = take("600519.SH", 1025)
ifind::thsRealTime(accToken, long_vec, "latest")

@testing:case = "test_Correctness_DateRange"
print("\n=== [完善] 正确性: 跨月/跨年日期 ===")
tb_cross = ifind::thsDateSequence(accToken, "600519.SH", "ths_pe_ttm_stock", "", "", "2024-12-25", "2025-01-05")
assert 18, tb_cross.rows() > 0

print("\n====================================================")
print("  iFinD 核心模块 [深度验证全覆盖版] 执行完毕  ")
print("====================================================")

