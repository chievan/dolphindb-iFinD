// --- 2.1 thsBasicData 异常校验 ---

@testing:case = "test_thsBasicData_arg_count_less", syntaxError=1
ifind::thsBasicData(accToken, "600519.SH")

@testing:case = "test_thsBasicData_arg_count_more", syntaxError=1
