@testing:case = "test_thsBasicData_token_type", exception=1
ifind::thsBasicData(12345, "600519.SH", "ths_roe_stock")

@testing:case = "test_thsBasicData_token_form", exception=1
ifind::thsBasicData(["tk1"], "600519.SH", "ths_roe_stock")

@testing:case = "test_thsBasicData_codes_type", exception=1
